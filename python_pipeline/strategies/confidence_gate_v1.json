{
  "name": "ConfidenceGate-1m",
  "version": "v1",
  "description": "FlowGate-1m features but with a probability confidence threshold — only predict when model confidence > threshold, skip (no trade) otherwise. Tests if selectivity improves directional MCC like Model A's FLAT filter.",
  "timeframe": "1m",
  "confidence_threshold": 0.60,
  "task_b": { "horizon_bars": 3, "k": 1.0, "vol_win": 30 },
  "feature_layers": {
    "order_flow_core":    ["cvd_ema3", "cvd_ema3_slope", "order_flow_vwap_deviation_pct", "volume_ad_line_zscore", "volume_obv_zscore"],
    "vwap_bands":         ["trend_vwap_session_rel", "trend_vwap_upper_1sd_rel", "trend_vwap_lower_1sd_rel", "trend_vwap_upper_2sd_rel", "trend_vwap_lower_2sd_rel"],
    "regime_gate":        ["directional_adx_14", "directional_di_plus", "directional_di_minus", "volatility_supertrend_10_3_rel", "directional_psar_trend_long"],
    "session_context":    ["order_flow_in_us_session", "order_flow_in_eu_session", "order_flow_in_asia_session"],
    "liquidity_sweeps":   ["order_flow_liquidity_sweep_up", "order_flow_liquidity_sweep_down", "order_flow_thin_zone"],
    "volatility_context": ["atr_pct", "volatility_bb_bandwidth_20", "volatility_ttm_squeeze_on", "vol_ratio"],
    "momentum":           ["momentum_rsi_14", "momentum_macd_hist_norm", "momentum_stoch_rsi_k", "momentum_stoch_rsi_d", "momentum_cci_20"]
  }
}
