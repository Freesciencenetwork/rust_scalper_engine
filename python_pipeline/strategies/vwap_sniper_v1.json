{
  "name": "VWAPSniper-1m",
  "version": "v1",
  "description": "Pure VWAP mean-reversion sniper. Uses VWAP bands as primary signal and momentum oscillators as confirmation. Documented 65-70% win rate in strict VWAP-reversion backtests.",
  "timeframe": "1m",
  "task_b": { "horizon_bars": 3, "k": 1.0, "vol_win": 30 },
  "feature_layers": {
    "vwap_primary":   ["trend_vwap_session_rel", "trend_vwap_upper_1sd_rel", "trend_vwap_lower_1sd_rel", "trend_vwap_upper_2sd_rel", "trend_vwap_lower_2sd_rel"],
    "oscillators":    ["momentum_rsi_14", "momentum_stoch_rsi_k", "momentum_stoch_rsi_d", "momentum_cci_20", "momentum_williams_r_14", "momentum_stoch_k", "momentum_stoch_d"],
    "bb_context":     ["volatility_bb_pct_b_20", "volatility_bb_bandwidth_20", "volatility_bb_upper_20_rel", "volatility_bb_lower_20_rel", "volatility_bb_middle_20_rel"],
    "volume_confirm": ["volume_cmf_20", "volume_obv_zscore", "volume_ad_line_zscore"],
    "session":        ["order_flow_in_us_session", "order_flow_in_eu_session", "order_flow_in_asia_session"]
  }
}
